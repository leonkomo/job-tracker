# ---------------------------------------------------------------------------
# SCRAPER 1: Deutsche Bundesbank (statisches HTML, mehrere Seiten)
# ---------------------------------------------------------------------------

BUNDESBANK_URLS = [
    "https://www.bundesbank.de/de/karriere/jobboerse",
    "https://www.bundesbank.de/action/de/729936/bbksearch?pageNumString=1",
    "https://www.bundesbank.de/action/de/729936/bbksearch?pageNumString=2",
    "https://www.bundesbank.de/action/de/729936/bbksearch?pageNumString=3",
    "https://www.bundesbank.de/action/de/729936/bbksearch?pageNumString=4",
]

# matched Detailseiten wie /de/karriere/jobboerse/irgendein-titel-867600
BUNDESBANK_DETAIL_RE = re.compile(r"^/de/karriere/jobboerse/.+-\d+$")


def _find_job_container(link, stop_text="Bewerbungsschluss", max_up=8):
    """Läuft von einem Element aus nach oben, bis der Container ALLE Stop-Texte
    enthält. stop_text kann ein einzelner String oder eine Liste von Strings
    sein (dann müssen alle im Container vorkommen, damit z.B. nicht schon die
    kleine Zeile mit dem Referenzcode allein als 'Container' durchgeht)."""
    required = [stop_text] if isinstance(stop_text, str) else list(stop_text)
    node = link
    for _ in range(max_up):
        if node.parent is None:
            break
        node = node.parent
        text = node.get_text()
        if all(r in text for r in required):
            return node
    return link.parent


def fetch_bundesbank() -> list[dict]:
    """Holt Stellenangebote von bundesbank.de (mehrere fest hinterlegte Seiten)."""
    jobs = []
    for url in BUNDESBANK_URLS:
        try:
            resp = requests.get(url, headers=HEADERS, timeout=20)
            resp.raise_for_status()
        except requests.RequestException as e:
            print(f"  [Fehler] Bundesbank ({url}): {e}")
            continue

        soup = BeautifulSoup(resp.text, "html.parser")
        for link in soup.find_all("a", href=True):
            if not BUNDESBANK_DETAIL_RE.match(link["href"]):
                continue
            container = _find_job_container(link)
            full_text = container.get_text(" ", strip=True)

            m = re.search(
                r"(.*?)Bewerbungsschluss:\s*(\d{2}\.\d{2}\.\d{4})\s*\|\s*([^|]+?)"
                r"(?:\s+/de/|\s+https?://|$)",
                full_text,
            )
            if m:
                title, deadline, location = m.group(1).strip(), m.group(2), m.group(3).strip()
            else:
                # Fallback: kein Muster erkannt -> nur den Linktext als Titel nehmen
                title, deadline, location = link.get_text(strip=True) or full_text[:80], "", ""

            if not title:
                continue

            full_url = "https://www.bundesbank.de" + link["href"]
            jobs.append(
                new_job("Deutsche Bundesbank", title, full_url, "bundesbank.de", location, deadline)
            )

    unique = {j["url"]: j for j in jobs}
    return list(unique.values())


# ---------------------------------------------------------------------------
# SCRAPER 2: Statistisches Bundesamt / Destatis (INTERAMT-Widget, JS -> Playwright)
# ---------------------------------------------------------------------------

DESTATIS_URL = "https://www.destatis.de/DE/Ueber-uns/Karriere/Stellenangebote/_inhalt.html"


def fetch_destatis() -> list[dict]:
    """Holt Stellenangebote von destatis.de. Die Tabelle wird per JS aus dem
    INTERAMT-Widget nachgeladen -> benötigt Playwright."""
    try:
        from playwright.sync_api import sync_playwright
    except ImportError:
        print(
            "  [Hinweis] Destatis-Scraping übersprungen: Playwright nicht installiert.\n"
            "            pip install playwright --break-system-packages\n"
            "            playwright install chromium"
        )
        return []

    jobs = []
    try:
        with sync_playwright() as p:
            browser = p.chromium.launch(headless=True)
            page = browser.new_page(user_agent=HEADERS["User-Agent"])
            page.goto(DESTATIS_URL, timeout=30000)
            page.wait_for_timeout(3000)  # Zeit für das Nachladen des Widgets geben

            # Manche Widgets laufen in einem Iframe (z.B. direkt von interamt.de)
            target = page
            for frame in page.frames:
                if "interamt" in frame.url:
                    target = frame
                    break

            try:
                target.wait_for_selector("table tbody tr, tr td a", timeout=15000)
            except Exception:
                pass  # ggf. leere Trefferliste, unten wird das abgefangen

            html = target.content()
            browser.close()
    except Exception as e:
        print(f"  [Fehler] Destatis: Seite konnte nicht geladen werden ({e})")
        return []

    soup = BeautifulSoup(html, "html.parser")
    rows = soup.select("table tbody tr") or soup.select("tr")

    for row in rows:
        cells = row.find_all("td")
        if len(cells) < 2:
            continue
        link = cells[0].find("a")
        title = (link.get_text(strip=True) if link else cells[0].get_text(strip=True))
        if not title:
            continue
        href = link.get("href", "") if link else ""
        full_url = href if href.startswith("http") else f"https://www.interamt.de{href}"

        # Spalten lt. Kopfzeile: Stellenangebote | Abschluss | Einsatzort | Online seit | Bewerbungsfrist | ...
        location = cells[2].get_text(strip=True) if len(cells) > 2 else ""
        deadline = cells[4].get_text(strip=True) if len(cells) > 4 else ""

        jobs.append(new_job("Statistisches Bundesamt", title, full_url, "destatis.de", location, deadline))

    unique = {j["url"]: j for j in jobs}
    return list(unique.values())


